{
    "database_path": "hash_database.json",
    "report_path": "reports/report_%Y-%m-%d_%H-%M-%S.log",
    "schedule": "",
    "default_args": "scan full",
    "include": [
        "/etc",
        "/bin",
        "/sbin",
        "/home"
    ],
    "exclude": [
        "/tmp",
        "/proc",
        "/sys",
        "/dev",
        "/run",
        "mask:*.tmp",
        "mask:*.cache",
        "mask:*.log"
    ],
    "follow_symlinks": false,
    "verbosity": "verbose",
    "use_colors": true
}